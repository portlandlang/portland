# The absence story, end to end (ADRs 0005–0010): nil is the empty case
# of a maybe, partial operations return maybes, and the only crash is one
# you typed.

config = {"theme" => "teal", "digest" => nil}

theme = config["theme"] or "grey"
puts theme

timeout = config["timeout"] or 30
puts timeout

p config["digest"]
p config["missing"]

def shout(word)
  found = word or return "..."
  found.upcase + "!"
end

puts shout("portland")
puts shout(nil)

scores = []
puts scores.first or 0

winner = [7, 3, 9].max or panic "scores went missing"
puts winner

name = config["nickname"]&.upcase or "FRIEND"
puts name

p nil.nil?
p "rose".some?
