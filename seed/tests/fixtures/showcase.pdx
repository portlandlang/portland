# A little of everything the seed understands so far.

def describe(number)
  if number < 0
    "negative"
  else
    if number == 0
      "zero"
    else
      "positive"
    end
  end
end

puts(describe(0 - 7)) # no unary minus yet, so 0 - 7
puts(describe(0))
puts(describe(7 * 6))

def average(left, right)
  (left + right) / 2
end

answer = average(40, 44)
puts(answer)
puts(answer == 42)
